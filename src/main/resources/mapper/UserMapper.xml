<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mail.mapper.UserMapper">

    <resultMap id="userMap" type="com.mail.entity.User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="email" column="email"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="salt" column="salt"/>
        <result property="qqEmail" column="qq_email"/>
        <result property="qqAuthCode" column="qq_auth_code"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findById" resultMap="userMap">
        SELECT * FROM users WHERE id = #{id}
    </select>

    <select id="findByUsername" resultMap="userMap">
        SELECT * FROM users WHERE username = #{username}
    </select>

    <select id="findByEmail" resultMap="userMap">
        SELECT * FROM users WHERE email = #{email}
    </select>

    <!-- BCrypt 内置 salt，salt 字段保留列但不再写入（始终为 NULL） -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (username, email, password_hash, created_at)
        VALUES (#{username}, #{email}, #{passwordHash}, NOW())
    </insert>

    <update id="updatePassword">
        UPDATE users SET password_hash = #{passwordHash} WHERE id = #{id}
    </update>

    <update id="updateUsername">
        UPDATE users SET username = #{username} WHERE id = #{id}
    </update>

    <select id="findAllWithQqBinding" resultMap="userMap">
        SELECT * FROM users WHERE qq_email IS NOT NULL AND qq_email != '' AND qq_auth_code IS NOT NULL AND qq_auth_code != ''
    </select>

    <update id="updateQqBinding">
        UPDATE users SET qq_email = #{qqEmail}, qq_auth_code = #{qqAuthCode} WHERE id = #{id}
    </update>

</mapper>
