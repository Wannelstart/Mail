# ========================================
# 邮件系统环境变量模板
# 复制本文件为 .env 并填入实际配置值
# ⚠️ 请勿将 .env 提交到版本控制
# ========================================

# 时区
TZ=Asia/Shanghai

# ---------- MySQL ----------
DB_HOST=localhost
DB_NAME=mail_system
DB_USER=root
DB_PASS=

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# ---------- JWT ----------
# 生产环境务必更换为随机强密钥（至少32字符）
JWT_SECRET=change-me-in-production-must-be-32-chars

# ---------- 应用配置 ----------
UPLOAD_DIR=/data/uploads
APP_MAIL_DOMAIN=lneqse.com
REMOTE_API_SECRET=CHANGE_ME
